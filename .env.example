# Copy to .env and fill in your keys
COHERE_API_KEY=your_cohere_key_here

# Optional — for the Research Companion agent's web search tool.
# Sign up at tavily.com (free tier: 1000 searches/month). Leave blank to disable.
TAVILY_API_KEY=

# LLM features on/off (true/false)
ENABLE_LLM=true

# Cohere models
COHERE_CHAT_MODEL=command-a-03-2025
COHERE_EMBED_MODEL=embed-english-v3.0

# Server
PORT=8765
DATA_DIR=/Users/dlwhyte/ReaderData
