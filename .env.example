# Copy this file to `.env` at the repo root and fill in your keys.
#
# Required for LLM features (Chat, Research agent, semantic search,
# auto-summary + auto-tags on save). Leave blank + set ENABLE_LLM=false
# below to run BrowseFellow as a plain reader.
COHERE_API_KEY=

# Optional — powers the Research agent's web-search tool.
# Sign up at tavily.com (free tier: 1000 searches/month).
TAVILY_API_KEY=

# LLM features on/off (true/false). When false, the reader still works
# but Chat / Research / summaries / auto-tags / semantic search are skipped.
ENABLE_LLM=true

# Cohere model IDs. Defaults are fine for most users.
COHERE_CHAT_MODEL=command-a-03-2025
COHERE_EMBED_MODEL=embed-english-v3.0

# Backend server port.
PORT=8765

# Where the SQLite shelf lives. Defaults to ~/ReaderData if unset.
# DATA_DIR=/path/to/ReaderData
